{
  "page": {
    "label": "TRANSLATE.PLUGIN_PAGE_LABEL"
  },
  "sections": [
    {
      "id": "section_general",
      "element": "section",
      "label": "TRANSLATE.GENERAL_SETTINGS",
      "icon": "fa-cog",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/ai_autopilot",
        "method": "saveGeneralSettings"
      },
      "saveButton": {
        "label": "TRANSLATE.SAVE",
        "data": [
          "enabled",
          "source",
          "trigger_mode",
          "keep_ahead_count",
          "cooldown_sec",
          "http_api_port",
          "history_window",
          "avoid_same_album_window",
          "avoid_same_artist_window",
          "feedback_use_skip",
          "verbose_log"
        ]
      },
      "content": [
        {
          "id": "enabled",
          "element": "switch",
          "label": "TRANSLATE.ENABLED",
          "value": true
        },
        {
          "id": "source",
          "element": "select",
          "label": "TRANSLATE.SOURCE",
          "doc": "TRANSLATE.SOURCE_DOC",
          "value": { "value": "auto", "label": "Auto (any)" },
          "options": [
            { "value": "auto",  "label": "Auto (any)" },
            { "value": "qobuz", "label": "Qobuz" },
            { "value": "tidal", "label": "TIDAL" },
            { "value": "mpd",   "label": "Local library (MPD)" }
          ]
        },
        {
          "id": "trigger_mode",
          "element": "select",
          "label": "TRANSLATE.TRIGGER_MODE",
          "doc": "TRANSLATE.TRIGGER_MODE_DOC",
          "value": { "value": "keep_ahead", "label": "TRANSLATE.TRIGGER_KEEP_AHEAD" },
          "options": [
            { "value": "queue_empty", "label": "TRANSLATE.TRIGGER_QUEUE_EMPTY" },
            { "value": "keep_ahead", "label": "TRANSLATE.TRIGGER_KEEP_AHEAD" },
            { "value": "manual", "label": "TRANSLATE.TRIGGER_MANUAL" }
          ]
        },
        {
          "id": "keep_ahead_count",
          "element": "input",
          "type": "number",
          "label": "TRANSLATE.KEEP_AHEAD_COUNT",
          "doc": "TRANSLATE.KEEP_AHEAD_COUNT_DOC",
          "value": 3,
          "attributes": [
            { "placeholder": "3" },
            { "min": 1 },
            { "max": 20 }
          ]
        },
        {
          "id": "cooldown_sec",
          "element": "input",
          "type": "number",
          "label": "TRANSLATE.COOLDOWN_SEC",
          "doc": "TRANSLATE.COOLDOWN_SEC_DOC",
          "value": 5,
          "attributes": [
            { "placeholder": "5" },
            { "min": 0 },
            { "max": 120 }
          ]
        },
        {
          "id": "history_window",
          "element": "input",
          "type": "number",
          "label": "TRANSLATE.HISTORY_WINDOW",
          "doc": "TRANSLATE.HISTORY_WINDOW_DOC",
          "value": 20,
          "attributes": [
            { "placeholder": "20" },
            { "min": 1 },
            { "max": 200 }
          ]
        },
        {
          "id": "avoid_same_album_window",
          "element": "input",
          "type": "number",
          "label": "TRANSLATE.AVOID_ALBUM",
          "doc": "TRANSLATE.AVOID_ALBUM_DOC",
          "value": 10,
          "attributes": [
            { "placeholder": "10" },
            { "min": 0 },
            { "max": 200 }
          ]
        },
        {
          "id": "avoid_same_artist_window",
          "element": "input",
          "type": "number",
          "label": "TRANSLATE.AVOID_ARTIST",
          "doc": "TRANSLATE.AVOID_ARTIST_DOC",
          "value": 0,
          "attributes": [
            { "placeholder": "0" },
            { "min": 0 },
            { "max": 200 }
          ]
        },
        {
          "id": "http_api_port",
          "element": "input",
          "type": "number",
          "label": "TRANSLATE.HTTP_API_PORT",
          "doc": "TRANSLATE.HTTP_API_PORT_DOC",
          "value": 3001,
          "attributes": [
            { "placeholder": "3001" },
            { "min": 0 },
            { "max": 65535 }
          ]
        },
        {
          "id": "feedback_use_skip",
          "element": "switch",
          "label": "TRANSLATE.FEEDBACK_USE_SKIP",
          "doc": "TRANSLATE.FEEDBACK_USE_SKIP_DOC",
          "value": false
        },
        {
          "id": "verbose_log",
          "element": "switch",
          "label": "TRANSLATE.VERBOSE_LOG",
          "value": false
        }
      ]
    },
